# Tmuxifier configuration.
#
# Copy this file to `.env` (which is gitignored) to keep the app self-contained:
#
#     cp .env.example .env
#
# Then run `npm run set-password` for password mode, or `npm run gen-secret`
# for OAuth mode.
# Everything else is optional — uncomment a line to override its default.
# Real shell environment variables, if set, take precedence over this file.

# --- Required secrets ---------------------------------------------------------
# scrypt hash of the login password. Required when TMUXIFIER_AUTH_MODE=password.
TMUXIFIER_PASSWORD_HASH=
# Secret used to sign the session and OAuth cookies. Keep it stable to avoid logging out.
TMUXIFIER_COOKIE_SECRET=

# --- Auth mode ---------------------------------------------------------------
# 'password' (default) or 'oauth'. In oauth mode the password login is gone.
#TMUXIFIER_AUTH_MODE=password

# --- OAuth / Google sign-in (required when TMUXIFIER_AUTH_MODE=oauth) --------
# Base external URL users reach. A scheme-less value defaults to https://. This
# builds the OAuth redirect URI and marks the session cookie Secure behind a
# TLS-terminating proxy like a Cloudflare tunnel.
#TMUXIFIER_BASE_EXTERNAL_URL=tmuxifier.example.com
# OAuth client from Google Cloud Console. See docs/DEPLOY.md.
#TMUXIFIER_OAUTH_CLIENT_ID=
#TMUXIFIER_OAUTH_CLIENT_SECRET=
# Comma-separated exact emails allowed to sign in (case-insensitive).
#TMUXIFIER_ALLOWED_EMAILS=you@example.com,teammate@example.com

# --- Passkeys (WebAuthn) ------------------------------------------------------
# A passkey is an additional, additive login path available in EITHER auth mode above (it
# is not a value of TMUXIFIER_AUTH_MODE). See the "Passkeys" section in README.md for the
# full picture, including the security-model notes on allowlist revocation and the
# per-address challenge bound.
#
# The hostname (WebAuthn "relying party id") passkeys are bound to. When this is left
# unset, it defaults to the hostname of TMUXIFIER_BASE_EXTERNAL_URL when that is set to a
# real domain name, or to "localhost" when TMUXIFIER_BASE_EXTERNAL_URL is unset entirely.
# Must be a real domain name — an IP address cannot be a WebAuthn relying party. If
# TMUXIFIER_BASE_EXTERNAL_URL is instead set to an IP address (not a hostname), the derived
# value is neither of the above — it is null, and passkeys are simply unavailable
# (everything else still works). An explicit TMUXIFIER_RP_ID below that is NOT a valid
# domain name is treated differently: that's a stated configuration mistake, and it fails
# startup rather than quietly disabling passkeys.
# CHANGING THIS INVALIDATES EVERY ENROLLED PASSKEY.
#TMUXIFIER_RP_ID=tmuxifier.example.com
#
# Break-glass for "Require a passkey" (Settings → Passkeys → sign-in policy). Set to "off"
# (case-insensitive; "0", "no" and "false" also work) and restart to force password/Google
# sign-in back on. Any other value, or leaving this unset, is a no-op — the kill switch
# stays disengaged. This is the only recovery path reachable without filesystem access if
# you lose every enrolled authenticator while that toggle is armed. It can only turn the
# requirement off; you arm it from the UI, not from here. (The camelCase config.json form,
# passkeyOnlyKillSwitch, is a plain boolean instead — see README.md.)
#TMUXIFIER_PASSKEY_ONLY=off

# --- Network -----------------------------------------------------------------
# Interface to bind. Stays on loopback unless you front it with TLS.
#TMUXIFIER_BIND=127.0.0.1
# Port to listen on.
#TMUXIFIER_PORT=7437
# Trust the reverse proxy's X-Forwarded-For so login rate limiting buckets by
# each client's real IP instead of the proxy's address. Set it when (and only
# when) Tmuxifier sits behind a reverse proxy or tunnel — trusting forwarded
# headers from direct clients lets them spoof their IP. Accepts true, a hop
# count, or a comma-separated address/CIDR list (Fastify trustProxy values).
#TMUXIFIER_TRUST_PROXY=true

# --- TLS (set BOTH to serve HTTPS directly; also marks the cookie Secure) -----
# Keep cert + key inside the repo (the tls/ dir is gitignored). See docs/DEPLOY.md.
#TMUXIFIER_TLS_CERT=tls/cert.pem
#TMUXIFIER_TLS_KEY=tls/key.pem

# --- SSH / sessions ----------------------------------------------------------
# Grace window (seconds) to keep a dropped PTY alive for seamless reconnects.
#TMUXIFIER_GRACE=45
# StrictHostKeyChecking policy passed to ssh.
#TMUXIFIER_HOSTKEY_POLICY=accept-new
# Alternate ssh config file passed to ssh with -F. This is not merged with ~/.ssh/config.
#TMUXIFIER_SSH_CONFIG=/path/to/extra_ssh_config
# Max boxes probed at once on /api/status. Keep it small so the status poll never
# opens the whole fleet's SSH connections simultaneously — a burst of dozens of
# SSH handshakes can trip connection-rate/IPS blocks on the path and make boxes
# flicker red until the block expires.
#TMUXIFIER_STATUS_CONCURRENCY=4
# How often (ms) the single server-side loop re-probes every box. Status is polled
# here once per interval no matter how many dashboard tabs are open, so the SSH
# connection rate doesn't scale with tab count.
#TMUXIFIER_STATUS_POLL_MS=30000
# ssh ControlPersist (seconds): how long a multiplexed master lingers after its
# last use. Higher keeps connections warm so cold-connect bursts (which cause the
# flicker above) are rare. ServerAliveInterval still reaps a dead master in ~45s.
#TMUXIFIER_CONTROL_PERSIST=600

# --- Terminal (browser xterm) ------------------------------------------------
# Font family for the terminal sessions (NOT the dashboard chrome). A single
# family name; it is PREPENDED to the bundled stack, which stays as the fallback,
# so the font must be installed on the device viewing the dashboard or that
# device transparently falls back to the bundled MesloLGMDZ Nerd Font (the
# default). An unsafe or empty value is ignored (bundled font is used).
# Examples: JetBrains Mono, Fira Code, MesloLGS NF.
#TMUXIFIER_TERM_FONT=JetBrains Mono
# Terminal font size in px (6–32). Out-of-range/non-numeric falls back to 12.
#TMUXIFIER_TERM_FONT_SIZE=12
# Max size (MB) for files pasted/dropped onto a terminal (default 25).
#TMUXIFIER_UPLOAD_MAX_MB=25

# --- Fleet Command -----------------------------------------------------------
# Run one command across many selected boxes as a pollable job. Concurrency keeps
# the fan-out small for the same reason as status probing (avoid SSH bursts).
#TMUXIFIER_FLEET_CONCURRENCY=4
# Per-box ssh exec timeout (ms).
#TMUXIFIER_FLEET_TIMEOUT_MS=15000
# How many past fleet jobs to keep in data/fleet-jobs.json (older are pruned).
#TMUXIFIER_FLEET_MAX_JOBS=50
# Per-stream (stdout/stderr) capture cap per box, in bytes.
#TMUXIFIER_FLEET_MAX_OUTPUT_BYTES=65536

# --- Box health history & in-app events --------------------------------------
# The status poll already collects CPU/mem/disk; these retain a rolling per-box
# series (for row sparklines) and an edge-triggered events log (persisted to
# data/health-events.json). No notifications are sent — in-app display only.
#TMUXIFIER_HEALTH_HISTORY_MAX=120
#TMUXIFIER_HEALTH_EVENTS_MAX=200
# Metric-threshold events fire when a box crosses these (percent), with a
# hysteresis margin before the "cleared" event re-arms them.
#TMUXIFIER_HEALTH_CPU_WARN_PCT=90
#TMUXIFIER_HEALTH_MEM_WARN_PCT=90
#TMUXIFIER_HEALTH_DISK_WARN_PCT=90
#TMUXIFIER_HEALTH_HYSTERESIS_PCT=5

# --- Storage (defaults stay inside the repo folder) --------------------------
# Where boxes.json and runtime state live. Defaults to <repo>/data.
#TMUXIFIER_DATA_DIR=./data
# Where SSH ControlMaster sockets live. Defaults to <dataDir>/cm.
#TMUXIFIER_CONTROL_DIR=./data/cm

# --- Proxmox LXC provisioning ------------------------------------------------
# Poll cadence (ms) for streaming a PVE create/start task's progress log.
#TMUXIFIER_PVE_POLL_MS=1500
# Per-request timeout (ms) for calls to the Proxmox API.
#TMUXIFIER_PVE_TIMEOUT_MS=15000
# Overall deadline (ms) for one provision (create + start + discover).
#TMUXIFIER_PVE_PROVISION_TIMEOUT_MS=600000
# How long (ms) to wait for a DHCP container to report a leased IP before
# finishing the job without an auto-linked box.
#TMUXIFIER_PVE_LEASE_TIMEOUT_MS=60000
# Retained provision-job history in data/provision-jobs.json (older pruned).
#TMUXIFIER_PVE_MAX_JOBS=50
# Public key injected into every provisioned container so Tmuxifier can SSH in.
# Defaults to auto-detecting ~/.ssh/id_{ed25519,rsa,ecdsa}(.pub) — set this to
# use a specific key file instead (the path is used exclusively, no fallback).
#TMUXIFIER_PVE_DEFAULT_PUBKEY=/root/.ssh/id_ed25519.pub
# NOTE: the Proxmox API token is NOT stored here. It is encrypted at rest in
# data/proxmox.json, with the key derived from TMUXIFIER_COOKIE_SECRET.

# --- AI CLI auth seeding (opt-in copying of AI credentials onto boxes) -------
# Long-lived Claude Code OAuth token (output of `claude setup-token`) used to
# seed provisioned boxes when "Seed AI CLI auth" is ticked. Full-account
# credential — treat like the password hash above.
#TMUXIFIER_CLAUDE_OAUTH_TOKEN=sk-ant-oat-EXAMPLE

# --- Agent activity detection (Claude pane idle notification) ------------------
# Seconds a Claude pane's tmux session must be silent before Tmuxifier treats it
# as waiting for your input (agent-input notification). Default 45; range 10-3600.
#TMUXIFIER_AGENT_IDLE_SEC=45

# --- Voice dictation (optional; off unless both paths below are set) ---
# Populated by `npm run setup-voice`. Set TMUXIFIER_VOICE=off to hard-disable
# voice regardless of what is installed.
#TMUXIFIER_WHISPER_BIN=./vendor/whisper/build/bin/whisper-server
#TMUXIFIER_WHISPER_MODEL=./vendor/whisper/models/ggml-small.en.bin
#TMUXIFIER_VOICE=off
#TMUXIFIER_VOICE_IDLE_MS=600000
#TMUXIFIER_VOICE_MAX_MB=8
#TMUXIFIER_VOICE_MAX_SECONDS=120
