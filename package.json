{
  "name": "tmuxifier",
  "version": "1.13.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "node --watch src/server/index.js",
    "build": "vite build",
    "start": "node src/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "set-password": "node scripts/hash-password.js",
    "gen-secret": "node scripts/gen-secret.js",
    "setup-voice": "node scripts/setup-voice.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.9.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@playwright/test": "^1.45.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "ws": "^8.18.0"
  }
}
